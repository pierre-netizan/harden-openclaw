{
  "id": "arsguard",
  "name": "arsguard",
  "description": "AI Agent 安全加固插件 — 拦截 OWASP Top 10 for AI Agents 安全风险",
  "version": "0.1.0",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "是否启用 arsguard 安全加固"
      },
      "ollama": {
        "type": "object",
        "properties": {
          "host": { "type": "string" },
          "target_model": { "type": "string" },
          "prompt_model": { "type": "string" }
        }
      },
      "hooks": {
        "type": "object",
        "description": "各 OWASP 钩子的独立配置（enable/disable/action）"
      }
    }
  },
  "uiHints": {
    "enabled": {
      "label": "启用 arsguard",
      "help": "开启/关闭所有安全拦截规则"
    }
  }
}
